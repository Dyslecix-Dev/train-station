NODE_ENV=""

# ──────────────────────────────────────────────────────────────────────────────
# WARNING: required — the app validates these at startup (see next.config.ts).
# Fill these in to run `pnpm dev`. Get values from your Supabase project dashboard under Settings → API and Settings → Database.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase (relational database) - create a free account at https://supabase.com/dashboard/organizations
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
POSTGRES_URL=""
POSTGRES_URL_NON_POOLING=""

# ──────────────────────────────────────────────────────────────────────────────
# NOTE: optional — validated if present, but the app starts without them.
# Features that depend on these will throw at runtime if used without the key.
# ──────────────────────────────────────────────────────────────────────────────

# Canonical app URL — used in email redirect links (e.g. https://myapp.com)
# Falls back to location.origin in the browser when not set
# NEXT_PUBLIC_APP_URL=""

# VAPID mailto for push notifications — your app's contact email (e.g. mailto:you@example.com)
VAPID_MAILTO=""

# Resend (transactional email) — create a free account at https://resend.com
RESEND_API_KEY=""
EMAIL_FROM=""

# VAPID keys for PWA push notifications — generate with: pnpm dlx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Upstash Redis (rate limiting) — create a free database at https://console.upstash.com
# Falls back to in-memory rate limiting when not set (fine for local dev)
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# File upload max size in MB (default: 5)
# UPLOAD_MAX_SIZE_MB="5"

# Structured logger level (debug | info | warn | error)
# Defaults to "debug" in development, "info" in production
# LOG_LEVEL="info"

# Auth rate limiting — max requests per window (defaults: 10 requests / 60s)
# AUTH_RATE_LIMIT="10"
# AUTH_RATE_WINDOW_MS="60000"

# Sentry (error tracking) — get your DSN at https://sentry.io
# Errors are silently dropped when not set
NEXT_PUBLIC_SENTRY_DSN=""

# ──────────────────────────────────────────────────────────────────────────────
# NOTE: auto-populated by the Vercel × Supabase integration — NOT used by app code.
# When you create a Supabase project through Vercel, these are provisioned automatically. Some are aliases for the same value under different naming conventions (e.g. ANON_KEY / PUBLISHABLE_KEY hold the same key).
# You can leave these blank if setting up manually — the app doesn't read them.
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_ANON_KEY=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""
SUPABASE_URL=""
POSTGRES_DATABASE=""
POSTGRES_HOST=""
POSTGRES_PASSWORD=""
POSTGRES_USER=""

# Not used by this project (Drizzle is the ORM, not Prisma). Auto-populated by Vercel.
POSTGRES_PRISMA_URL=""

# ──────────────────────────────────────────────────────────────────────────────
# NOTE: auto-populated by the Vercel × Upstash integration — NOT used by app code.
# When you create an Upstash Redis database through Vercel, these are provisioned automatically.
# The app only reads KV_REST_API_URL and KV_REST_API_TOKEN (in the optional section above).
# ──────────────────────────────────────────────────────────────────────────────
KV_REST_API_READ_ONLY_TOKEN=""
KV_URL=""
REDIS_URL=""

# ──────────────────────────────────────────────────────────────────────────────
# NOTE: MCP servers (AI-assisted development only) — not needed for the app itself.
# ──────────────────────────────────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=""
UPSTASH_EMAIL=""
UPSTASH_API_KEY=""
